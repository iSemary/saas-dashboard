{
  "info": {
    "name": "SaaS Dashboard — POS, Sales & Inventory",
    "_postman_id": "saas-pos-sales-inventory-v1",
    "description": "API collection for POS, Sales, and Inventory bounded contexts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "YOUR_BEARER_TOKEN_HERE" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "POS",
      "item": [
        {
          "name": "Dashboard",
          "item": [
            { "name": "POS Dashboard", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/dashboard" } }
          ]
        },
        {
          "name": "Products",
          "item": [
            { "name": "List Products", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/products?page=1&per_page=15" } },
            { "name": "Get Product", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/products/1" } },
            { "name": "Create Product", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/products", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Widget\",\n  \"purchase_price\": 10.00,\n  \"sale_price\": 15.00,\n  \"amount\": 100,\n  \"barcode_number\": \"1234567890\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Update Product", "request": { "method": "PUT", "url": "{{base_url}}/tenant/pos/products/1", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Widget Updated\",\n  \"sale_price\": 18.00\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Product", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/pos/products/1" } },
            { "name": "Bulk Delete Products", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/products/bulk-delete", "body": { "mode": "raw", "raw": "{\n  \"ids\": [1, 2, 3]\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Change Stock", "request": { "method": "PATCH", "url": "{{base_url}}/tenant/pos/products/1/stock", "body": { "mode": "raw", "raw": "{\n  \"amount\": 10,\n  \"direction\": \"increment\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Search by Barcode", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/products/barcode/1234567890" } }
          ]
        },
        {
          "name": "Categories",
          "item": [
            { "name": "List Categories", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/categories" } },
            { "name": "Create Category", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/categories", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Update Category", "request": { "method": "PUT", "url": "{{base_url}}/tenant/pos/categories/1", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics Updated\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Category", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/pos/categories/1" } }
          ]
        },
        {
          "name": "Sub-Categories",
          "item": [
            { "name": "List Sub-Categories", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/sub-categories" } },
            { "name": "Create Sub-Category", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/sub-categories", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Phones\",\n  \"category_id\": 1\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Update Sub-Category", "request": { "method": "PUT", "url": "{{base_url}}/tenant/pos/sub-categories/1", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mobile Phones\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Sub-Category", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/pos/sub-categories/1" } }
          ]
        },
        {
          "name": "Barcodes",
          "item": [
            { "name": "List Barcodes", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/barcodes" } },
            { "name": "Create Barcode", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/barcodes", "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"barcode_number\": \"0987654321\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Search Barcode", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/barcodes/search/0987654321" } },
            { "name": "Delete Barcode", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/pos/barcodes/1" } }
          ]
        },
        {
          "name": "Offer Prices",
          "item": [
            { "name": "List Offer Prices", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/offer-prices" } },
            { "name": "Create Offer Price", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/offer-prices", "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"offer_price\": 12.00,\n  \"start_date\": \"2025-01-01\",\n  \"end_date\": \"2025-01-31\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Update Offer Price", "request": { "method": "PUT", "url": "{{base_url}}/tenant/pos/offer-prices/1", "body": { "mode": "raw", "raw": "{\n  \"offer_price\": 11.00\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Offer Price", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/pos/offer-prices/1" } }
          ]
        },
        {
          "name": "Damaged",
          "item": [
            { "name": "List Damaged", "request": { "method": "GET", "url": "{{base_url}}/tenant/pos/damaged" } },
            { "name": "Record Damaged", "request": { "method": "POST", "url": "{{base_url}}/tenant/pos/damaged", "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"amount\": 5\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Damaged Record", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/pos/damaged/1" } }
          ]
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        { "name": "Daily Summary", "request": { "method": "GET", "url": "{{base_url}}/tenant/sales/summary?date=2025-04-25" } },
        {
          "name": "Orders",
          "item": [
            { "name": "List Orders", "request": { "method": "GET", "url": "{{base_url}}/tenant/sales/orders?page=1&per_page=15" } },
            { "name": "Get Order", "request": { "method": "GET", "url": "{{base_url}}/tenant/sales/orders/1" } },
            { "name": "Create Order (Cash / Takeaway)", "request": { "method": "POST", "url": "{{base_url}}/tenant/sales/orders", "body": { "mode": "raw", "raw": "{\n  \"products\": [\n    { \"product_id\": 1, \"quantity\": 2, \"unit_price\": 15.00, \"total_price\": 30.00 }\n  ],\n  \"total_price\": 30.00,\n  \"amount_paid\": 30.00,\n  \"pay_method\": \"cash\",\n  \"order_type\": \"takeaway\",\n  \"branch_id\": 1\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Create Order (Card / Takeaway)", "request": { "method": "POST", "url": "{{base_url}}/tenant/sales/orders", "body": { "mode": "raw", "raw": "{\n  \"products\": [\n    { \"product_id\": 1, \"quantity\": 1, \"unit_price\": 15.00, \"total_price\": 15.00 }\n  ],\n  \"total_price\": 15.00,\n  \"amount_paid\": 15.00,\n  \"pay_method\": \"card\",\n  \"transaction_number\": \"TXN-001\",\n  \"order_type\": \"takeaway\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Create Order (Installment / Delivery)", "request": { "method": "POST", "url": "{{base_url}}/tenant/sales/orders", "body": { "mode": "raw", "raw": "{\n  \"products\": [\n    { \"product_id\": 2, \"quantity\": 1, \"unit_price\": 100.00, \"total_price\": 100.00 }\n  ],\n  \"total_price\": 100.00,\n  \"amount_paid\": 20.00,\n  \"pay_method\": \"installment\",\n  \"order_type\": \"delivery\",\n  \"total_months\": 5,\n  \"monthly_amount\": 20.00,\n  \"delivery_name\": \"John Doe\",\n  \"delivery_phone\": \"+1234567890\",\n  \"delivery_address\": \"123 Main St\",\n  \"delivery_fee\": 5.00\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Cancel Order", "request": { "method": "PATCH", "url": "{{base_url}}/tenant/sales/orders/1/cancel" } },
            { "name": "Delete Order", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/sales/orders/1" } },
            { "name": "Bulk Delete Orders", "request": { "method": "POST", "url": "{{base_url}}/tenant/sales/orders/bulk-delete", "body": { "mode": "raw", "raw": "{\n  \"ids\": [1, 2]\n}", "options": { "raw": { "language": "json" } } } } }
          ]
        },
        {
          "name": "Clients",
          "item": [
            { "name": "List Clients", "request": { "method": "GET", "url": "{{base_url}}/tenant/sales/clients" } },
            { "name": "Get Client", "request": { "method": "GET", "url": "{{base_url}}/tenant/sales/clients/1" } },
            { "name": "Create Client", "request": { "method": "POST", "url": "{{base_url}}/tenant/sales/clients", "body": { "mode": "raw", "raw": "{\n  \"user_id\": 1,\n  \"code\": \"CLT-001\",\n  \"phone\": \"+20123456789\",\n  \"address\": \"123 Main St, Cairo\",\n  \"gift\": 50.00\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Update Client", "request": { "method": "PUT", "url": "{{base_url}}/tenant/sales/clients/1", "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+20987654321\",\n  \"gift\": 75.00\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Client", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/sales/clients/1" } }
          ]
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Warehouses",
          "item": [
            { "name": "List Warehouses", "request": { "method": "GET", "url": "{{base_url}}/tenant/inventory/warehouses?page=1&per_page=15" } },
            { "name": "All Warehouses (no pagination)", "request": { "method": "GET", "url": "{{base_url}}/tenant/inventory/warehouses?all=true" } },
            { "name": "Get Warehouse", "request": { "method": "GET", "url": "{{base_url}}/tenant/inventory/warehouses/1" } },
            { "name": "Create Warehouse", "request": { "method": "POST", "url": "{{base_url}}/tenant/inventory/warehouses", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Main Warehouse\",\n  \"code\": \"WH-001\",\n  \"address\": \"123 Storage St\",\n  \"city\": \"Cairo\",\n  \"is_active\": true,\n  \"is_default\": true\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Update Warehouse", "request": { "method": "PUT", "url": "{{base_url}}/tenant/inventory/warehouses/1", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Main Warehouse Updated\",\n  \"is_active\": true\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Delete Warehouse", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/inventory/warehouses/1" } },
            { "name": "Stock Summary", "request": { "method": "GET", "url": "{{base_url}}/tenant/inventory/warehouses/1/stock-summary?product_id=5" } }
          ]
        },
        {
          "name": "Stock Moves",
          "item": [
            { "name": "List Stock Moves", "request": { "method": "GET", "url": "{{base_url}}/tenant/inventory/stock-moves?warehouse_id=1&move_type=in" } },
            { "name": "Get Stock Move", "request": { "method": "GET", "url": "{{base_url}}/tenant/inventory/stock-moves/1" } },
            { "name": "Create Stock Move (Inbound)", "request": { "method": "POST", "url": "{{base_url}}/tenant/inventory/stock-moves", "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"warehouse_id\": 1,\n  \"move_type\": \"in\",\n  \"quantity\": 50,\n  \"unit_cost\": 10.00,\n  \"date\": \"2025-04-25\",\n  \"description\": \"Initial stock\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Create Stock Move (Outbound)", "request": { "method": "POST", "url": "{{base_url}}/tenant/inventory/stock-moves", "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"warehouse_id\": 1,\n  \"move_type\": \"out\",\n  \"quantity\": 10,\n  \"unit_cost\": 10.00,\n  \"date\": \"2025-04-25\"\n}", "options": { "raw": { "language": "json" } } } } },
            { "name": "Confirm Stock Move", "request": { "method": "PATCH", "url": "{{base_url}}/tenant/inventory/stock-moves/1/confirm" } },
            { "name": "Complete Stock Move", "request": { "method": "PATCH", "url": "{{base_url}}/tenant/inventory/stock-moves/1/complete" } },
            { "name": "Cancel Stock Move", "request": { "method": "PATCH", "url": "{{base_url}}/tenant/inventory/stock-moves/1/cancel" } },
            { "name": "Delete Stock Move", "request": { "method": "DELETE", "url": "{{base_url}}/tenant/inventory/stock-moves/1" } }
          ]
        }
      ]
    }
  ]
}
