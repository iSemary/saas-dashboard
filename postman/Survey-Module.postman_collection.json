{
  "info": {
    "name": "Survey Module",
    "description": "Full Survey Module API Collection - Authenticated Tenant Routes + Public Respondent Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tenant Routes (Authenticated)",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tenant/survey/dashboard",
              "host": ["{{base_url}}"],
              "path": ["tenant", "survey", "dashboard"]
            }
          }
        },
        {
          "name": "Surveys",
          "item": [
            {
              "name": "List Surveys",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys"]
                }
              }
            },
            {
              "name": "Create Survey",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Customer Satisfaction Survey\",\n  \"description\": \"Help us improve our services\",\n  \"status\": \"draft\"\n}"
                }
              }
            },
            {
              "name": "Get Survey",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}"]
                }
              }
            },
            {
              "name": "Update Survey",
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Updated Survey Title\"\n}"
                }
              }
            },
            {
              "name": "Delete Survey",
              "request": {
                "method": "DELETE",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}"]
                }
              }
            },
            {
              "name": "Publish Survey",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/publish",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "publish"]
                }
              }
            },
            {
              "name": "Duplicate Survey",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/duplicate",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "duplicate"]
                }
              }
            }
          ]
        },
        {
          "name": "Pages",
          "item": [
            {
              "name": "List Pages",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/pages",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "pages"]
                }
              }
            },
            {
              "name": "Create Page",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/pages",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "pages"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Page 1\",\n  \"order\": 1\n}"
                }
              }
            },
            {
              "name": "Reorder Pages",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/pages/reorder",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "pages", "reorder"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ordered_ids\": [3, 1, 2]\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Questions",
          "item": [
            {
              "name": "List Questions",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/questions",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "questions"]
                }
              }
            },
            {
              "name": "Create Question",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/questions",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "questions"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"type\": \"multiple_choice\",\n  \"title\": \"How satisfied are you?\",\n  \"is_required\": true,\n  \"options\": [\n    {\"label\": \"Very Satisfied\", \"value\": \"5\"},\n    {\"label\": \"Satisfied\", \"value\": \"4\"},\n    {\"label\": \"Neutral\", \"value\": \"3\"},\n    {\"label\": \"Dissatisfied\", \"value\": \"2\"},\n    {\"label\": \"Very Dissatisfied\", \"value\": \"1\"}\n  ]\n}"
                }
              }
            },
            {
              "name": "Reorder Questions",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/questions/reorder",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "questions", "reorder"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ordered_ids\": [2, 1, 3]\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Responses",
          "item": [
            {
              "name": "List Responses",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/responses",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "responses"]
                }
              }
            },
            {
              "name": "Get Response Details",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/responses/{{response_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "responses", "{{response_id}}"]
                }
              }
            },
            {
              "name": "Delete Response",
              "request": {
                "method": "DELETE",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/responses/{{response_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "responses", "{{response_id}}"]
                }
              }
            }
          ]
        },
        {
          "name": "Analytics",
          "item": [
            {
              "name": "Survey Analytics",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/analytics",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "analytics"]
                }
              }
            },
            {
              "name": "Export Responses",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/analytics/export?format=csv",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "analytics", "export"],
                  "query": [
                    {
                      "key": "format",
                      "value": "csv"
                    }
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Shares",
          "item": [
            {
              "name": "List Shares",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/shares",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "shares"]
                }
              }
            },
            {
              "name": "Create Share",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{tenant_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/tenant/survey/surveys/{{survey_id}}/shares",
                  "host": ["{{base_url}}"],
                  "path": ["tenant", "survey", "surveys", "{{survey_id}}", "shares"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"channel\": \"link\",\n  \"max_uses\": null\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Templates & Themes",
          "item": [
            {
              "name": "List Templates",
