      ]
    },
    {
      "name": "Public Routes (No Auth)",
      "item": [
        {
          "name": "Render Survey",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/public/survey/{{share_token}}",
              "host": ["{{base_url}}"],
              "path": ["public", "survey", "{{share_token}}"]
            }
          }
        },
        {
          "name": "Start Survey Response",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/survey/{{share_token}}/start",
              "host": ["{{base_url}}"],
              "path": ["public", "survey", "{{share_token}}", "start"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"respondent_email\": \"test@example.com\",\n  \"respondent_name\": \"John Doe\"\n}"
            }
          }
        },
        {
          "name": "Submit Answer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/survey/{{share_token}}/answer",
              "host": ["{{base_url}}"],
              "path": ["public", "survey", "{{share_token}}", "answer"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"response_id\": {{response_id}},\n  \"question_id\": {{question_id}},\n  \"value\": \"5\"\n}"
            }
          }
        },
        {
          "name": "Complete Survey",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/survey/{{share_token}}/complete",
              "host": ["{{base_url}}"],
              "path": ["public", "survey", "{{share_token}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"response_id\": {{response_id}}\n}"
            }
          }
        },
        {
          "name": "Resume Survey",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/public/survey/{{share_token}}/resume/{{resume_token}}",
              "host": ["{{base_url}}"],
              "path": ["public", "survey", "{{share_token}}", "resume", "{{resume_token}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Embed Routes",
      "item": [
        {
          "name": "Get Embed HTML",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/embed/survey/{{share_token}}",
              "host": ["{{base_url}}"],
              "path": ["embed", "survey", "{{share_token}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "tenant_token",
      "value": "your-jwt-token-here"
    },
    {
      "key": "survey_id",
      "value": "1"
    },
    {
      "key": "share_token",
      "value": "abc123xyz"
    },
    {
      "key": "response_id",
      "value": "1"
    },
    {
      "key": "resume_token",
      "value": "resume-token-here"
    },
    {
      "key": "template_id",
      "value": "1"
    },
    {
      "key": "question_id",
      "value": "1"
    }
  ]
}
