                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Ahmed Hassan\",\n  \"email\": \"ahmed@techcorp.com\",\n  \"password\": \"SecurePass123\",\n  \"password_confirmation\": \"SecurePass123\",\n  \"country_id\": 1,\n  \"customer_title\": \"TechCorp Solutions\",\n  \"customer_username\": \"techcorp\",\n  \"category_id\": 3\n}",
